TELEGRAM_BOT_TOKEN=123456789:your_bot_token_from_botfather

# Tubeo / TodoTrails Supabase project. Run these Tubeo SQL files there first:
# D:\Tubeo\docs\supabase-saved-videos-schema.sql
TUBEO_SUPABASE_URL=https://your-todotrails-project.supabase.co
TUBEO_SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
TUBEO_SUPABASE_SAVED_VIDEOS_TABLE=tubeo_saved_videos

# Tubeo owner whose Watch Later should be updated.
TUBEO_TELEGRAM_OWNER_EMAIL=you@example.com
TUBEO_TELEGRAM_OWNER_NAME=

BOT_MODE=polling
