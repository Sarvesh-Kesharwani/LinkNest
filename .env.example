LEGACY_LINKS_TABLE=saved_links
LINKNEST_CONVERSATION_TABLE=linknest_conversations
LEGACY_ARCHIVE_FETCH_LIMIT=200
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

